{
  "manifest_version": 3,
  "name": "Shorts AutoSkip",
  "version": "2.0.2",
  "description": "유튜브 쇼츠를 설정한 횟수만큼 재생 후 자동으로 넘깁니다.",

  "permissions": ["storage"],
  "host_permissions": ["*://*.youtube.com/*"],

  "icons": {
    "256": "icons/icon256.png"
  },

  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],

  "web_accessible_resources": [
    {
      "resources": ["icons/*.*"],
      "matches": ["*://*.youtube.com/*"]
    }
  ],

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "128": "icons/icon128.png"
    }
  }
}